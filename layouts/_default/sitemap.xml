{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- /* Every page Hugo actually renders: home, the standalone pages (archive,
    bits, changelog), blog posts and the taxonomy/term pages. render:never
    pages (individual bits, the unrendered blog section index) carry an empty
    Permalink, so filtering on Permalink keeps their empty <loc> out. */ -}}
  {{- range site.Pages }}
    {{- if .Permalink }}
    <url>
      <loc>{{ .Permalink }}</loc>
      {{- if not .Lastmod.IsZero }}
      <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
      {{- end }}
      {{- with .Sitemap.ChangeFreq }}
      <changefreq>{{ . }}</changefreq>
      {{- end }}
      {{- if ge .Sitemap.Priority 0.0 }}
      <priority>{{ .Sitemap.Priority }}</priority>
      {{- end }}
    </url>
    {{- end }}
  {{- end }}
</urlset>
