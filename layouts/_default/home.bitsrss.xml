{{- /* Bits - quotes, links, videos, blurbs only.

  Bits ave no permalink of their own. We point each item at its anchor on the
  /bits page (#bit-<name>), except link/video bits which point straight at their
  external target. The anchor doubles as a stable, non-resolvable guid. */ -}}
{{- $bits := (where site.RegularPages "Section" "bits").ByDate.Reverse -}}
{{- $author := "" -}}
{{- with site.Params.author -}}
  {{- $author = printf "%s (%s)" .email .name -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ site.Title }} · Bits</title>
    <link>{{ site.BaseURL }}bits/</link>
    <description>Nibbles, bits and bytes — short-form quotes, links and videos from {{ site.Title }}.</description>
    <generator>Hugo</generator>
    <language>{{ or site.Language.Locale "en-US" }}</language>
    {{- with $author }}
    <managingEditor>{{ . }}</managingEditor>
    <webMaster>{{ . }}</webMaster>
    {{- end }}
    {{- with $bits }}
    <lastBuildDate>{{ (index . 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}
    {{- with .OutputFormats.Get "BitsRSS" }}
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml" />
    {{- end }}
    {{- range $bits }}
      {{- $type := .Type }}
      {{- $anchor := printf "%sbits/#bit-%s" site.BaseURL .File.ContentBaseName }}
      {{- $link := $anchor }}

      {{- if or (eq $type "link") (eq $type "video") }}{{ $link = .Params.link }}{{ end }}
      {{- $title := .Title }}
      {{- if eq $type "quote" }}
        {{- $title = printf "Quote — %s" (.Params.source | default "Anonymous") }}
      {{- else if eq $type "blurb" }}
        {{- $title = .Content | plainify | strings.TrimSpace | truncate 80 }}
      {{- end }}

      {{- $desc := .Content }}
      {{- if eq $type "quote" }}
        {{- $desc = printf "<blockquote>%s</blockquote>" .Content }}
        {{- with .Params.source }}{{ $desc = printf "%s<p>&mdash; %s</p>" $desc . }}{{ end }}
      {{- else if or (eq $type "link") (eq $type "video") }}
        {{- with .Params.source }}{{ $desc = printf "%s<p><em>%s</em></p>" $desc . }}{{ end }}
        {{- $desc = printf "%s<p><a href=\"%s\">%s &rarr;</a></p>" $desc .Params.link .Title }}
      {{- end }}
    <item>
      <title>{{ $title | plainify | transform.XMLEscape | safeHTML }}</title>
      <link>{{ $link }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      {{- with $author }}
      <author>{{ . }}</author>
      {{- end }}
      <category>{{ $type }}</category>
      {{- range .Params.tags }}
      <category>{{ . | transform.XMLEscape | safeHTML }}</category>
      {{- end }}
      <guid isPermaLink="false">{{ $anchor }}</guid>
      <description>{{ $desc | transform.XMLEscape | safeHTML }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
